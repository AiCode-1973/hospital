# ============================================================
# .htaccess — Hospital Santo Expedito - APAS
# ============================================================

Options -Indexes

# ── Redireciona HTTP → HTTPS em produção ────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Força HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Força sem www → com www (remova se preferir sem www)
    # RewriteCond %{HTTP_HOST} ^hsesantos\.com\.br [NC]
    # RewriteRule ^ https://www.hsesantos.com.br%{REQUEST_URI} [R=301,L]

    # Força com www → sem www (ativo por padrão)
    RewriteCond %{HTTP_HOST} ^www\.hsesantos\.com\.br [NC]
    RewriteRule ^ https://hsesantos.com.br%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Segurança: oculta cabeçalhos sensíveis ──────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set X-XSS-Protection        "1; mode=block"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
</IfModule>

# ── Protege arquivos sensíveis ──────────────────────────────
<FilesMatch "(config\.php|\.env|composer\.(json|lock)|package\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Protege pasta de logs ────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteRule ^logs/ - [F,L]
</IfModule>

# ── Compressão Gzip ─────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json text/plain
</IfModule>

# ── Cache de assets estáticos ───────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg        "access plus 1 year"
    ExpiresByType image/png         "access plus 1 year"
    ExpiresByType image/webp        "access plus 1 year"
    ExpiresByType image/svg+xml     "access plus 1 year"
    ExpiresByType text/css          "access plus 3 months"
    ExpiresByType application/javascript "access plus 3 months"
    ExpiresByType application/x-font-woff2 "access plus 1 year"
</IfModule>

# ── Charset padrão ──────────────────────────────────────────
AddDefaultCharset UTF-8

# ── Página de erro personalizada ────────────────────────────
ErrorDocument 404 /index.php
